{
  "name": "Camer360 AI Enhancement",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [{ "field": "minutes", "minutesInterval": 30 }]
        }
      },
      "id": "schedule",
      "name": "Every 30 Minutes",
      "type": "n8n-nodes-base.scheduleTrigger",
      "position": [240, 300]
    },
    {
      "parameters": {
        "operation": "select",
        "table": "ingested_content",
        "additionalFields": {
          "where": "status = 'queued'",
          "limit": 5,
          "sort": "score DESC"
        }
      },
      "id": "fetch-queue",
      "name": "Fetch Queued Items",
      "type": "n8n-nodes-base.mysql",
      "position": [460, 300]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://camer360com.vercel.app/api/n8n/claude",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [{ "name": "x-api-key", "value": "={{ $env.CAMER360_AUTO_KEY }}" }]
        },
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            {
              "name": "system",
              "value": "You are a sharp, plugged-in African entertainment editor for Camer360, West and Central Africa's premier celebrity and lifestyle magazine. Write bold, punchy, entertaining copy. Embrace drama. Name names. Keep it factual but never boring. Celebrate African excellence.\n\nRespond ONLY with JSON:\n{\"title\":\"scroll-stopping headline under 12 words\",\"slug\":\"url-slug\",\"excerpt\":\"2 sentence teaser under 160 chars\",\"body\":\"full article HTML using <p> <h2> <strong> tags, 400-600 words\",\"metaTitle\":\"SEO title under 60 chars\",\"metaDesc\":\"SEO description under 160 chars\",\"tags\":[\"tag1\",\"tag2\",\"tag3\"]}"
            },
            {
              "name": "user",
              "value": "=Category: {{ $json.category }}\nOriginal title: {{ $json.title }}\nSource: {{ $json.source_url }}\nContent: {{ $json.summary }}"
            }
          ]
        },
        "options": { "timeout": 45000 }
      },
      "id": "enhance",
      "name": "AI Enhance Article",
      "type": "n8n-nodes-base.httpRequest",
      "position": [680, 300]
    },
    {
      "parameters": {
        "jsCode": "const item = $input.first();\ntry {\n  const enhanced = JSON.parse(item.json.text || '{}');\n  return [{ json: { id: item.json.id, category: item.json.category, ...enhanced } }];\n} catch {\n  return [];\n}"
      },
      "id": "parse-enhanced",
      "name": "Parse Enhanced Article",
      "type": "n8n-nodes-base.code",
      "position": [900, 300]
    },
    {
      "parameters": {
        "operation": "insert",
        "table": "articles",
        "columns": "title,slug,excerpt,body,category_id,meta_title,meta_desc,status,source_url,created_at",
        "additionalFields": {}
      },
      "id": "insert-article",
      "name": "Insert Draft Article",
      "type": "n8n-nodes-base.mysql",
      "position": [1120, 300],
      "notes": "status='draft' — admin reviews before publish. Map category slug to category_id via lookup or inline CASE."
    },
    {
      "parameters": {
        "operation": "update",
        "table": "ingested_content",
        "updateKey": "id",
        "columns": "status",
        "additionalFields": {}
      },
      "id": "mark-processed",
      "name": "Mark as Processed",
      "type": "n8n-nodes-base.mysql",
      "position": [1320, 300],
      "notes": "Set status='processed' on the ingested_content row"
    }
  ],
  "connections": {
    "Every 30 Minutes":    { "main": [[{ "node": "Fetch Queued Items", "type": "main", "index": 0 }]] },
    "Fetch Queued Items":  { "main": [[{ "node": "AI Enhance Article", "type": "main", "index": 0 }]] },
    "AI Enhance Article":  { "main": [[{ "node": "Parse Enhanced Article", "type": "main", "index": 0 }]] },
    "Parse Enhanced Article": { "main": [[{ "node": "Insert Draft Article", "type": "main", "index": 0 }]] },
    "Insert Draft Article": { "main": [[{ "node": "Mark as Processed", "type": "main", "index": 0 }]] }
  },
  "settings": { "executionOrder": "v1" }
}
