        { "node": "OkayAfrica RSS", "type": "main", "index": 0 },
        { "node": "Trace Africa RSS", "type": "main", "index": 0 }
      ]]
    },
    "Linda Ikeji RSS":   { "main": [[{ "node": "Deduplicate", "type": "main", "index": 0 }]] },
    "Pulse Nigeria RSS": { "main": [[{ "node": "Deduplicate", "type": "main", "index": 0 }]] },
    "Pulse Ghana RSS":   { "main": [[{ "node": "Deduplicate", "type": "main", "index": 0 }]] },
    "BellaNaija RSS":    { "main": [[{ "node": "Deduplicate", "type": "main", "index": 0 }]] },
