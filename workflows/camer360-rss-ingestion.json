{
  "name": "Camer360 RSS Ingestion",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [{ "field": "hours", "hoursInterval": 2 }]
        }
      },
      "id": "schedule",
      "name": "Every 2 Hours",
      "type": "n8n-nodes-base.scheduleTrigger",
      "position": [240, 300]
    },
    {
      "parameters": {
        "url": "https://www.lindaikejisblog.com/feeds/posts/default"
      },
      "id": "rss-linda",
      "name": "Linda Ikeji RSS",
      "type": "n8n-nodes-base.rssFeedRead",
      "position": [460, 160]
    },
    {
      "parameters": {
        "url": "https://www.pulse.ng/rss"
      },
      "id": "rss-pulse-ng",
      "name": "Pulse Nigeria RSS",
      "type": "n8n-nodes-base.rssFeedRead",
      "position": [460, 280]
    },
    {
      "parameters": {
        "url": "https://www.pulse.com.gh/rss"
      },
      "id": "rss-pulse-gh",
      "name": "Pulse Ghana RSS",
      "type": "n8n-nodes-base.rssFeedRead",
      "position": [460, 400]
    },
    {
      "parameters": {
        "url": "https://www.bellanaija.com/feed/"
      },
      "id": "rss-bellanaija",
      "name": "BellaNaija RSS",
      "type": "n8n-nodes-base.rssFeedRead",
      "position": [460, 520]
    },
    {
      "parameters": {
        "url": "https://thenet.ng/feed/"
      },
      "id": "rss-thenet",
      "name": "The Net NG RSS",
      "type": "n8n-nodes-base.rssFeedRead",
      "position": [460, 640]
    },
    {
      "parameters": {
        "url": "https://www.okayafrica.com/rss/"
      },
      "id": "rss-okayafrica",
      "name": "OkayAfrica RSS",
      "type": "n8n-nodes-base.rssFeedRead",
      "position": [460, 760]
    },
    {
      "parameters": {
        "url": "http://fr.trace.tv/trace-africa/feed/"
      },
      "id": "rss-trace",
      "name": "Trace Africa RSS",
      "type": "n8n-nodes-base.rssFeedRead",
      "position": [460, 880]
    },
    {
      "parameters": {
        "jsCode": "const items = $input.all();\nconst seen = new Set();\nreturn items.filter(item => {\n  const key = (item.json.link || item.json.guid || item.json.title || '').toLowerCase();\n  if (seen.has(key) || !key) return false;\n  seen.add(key);\n  return true;\n});"
      },
      "id": "dedup",
      "name": "Deduplicate",
      "type": "n8n-nodes-base.code",
      "position": [700, 520]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://camer360com.vercel.app/api/n8n/claude",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [{ "name": "x-api-key", "value": "={{ $env.CAMER360_AUTO_KEY }}" }]
        },
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            {
              "name": "system",
              "value": "You are a sharp African entertainment editor for Camer360. Classify and score this article. Respond ONLY with JSON: {\"publish\":true/false,\"category\":\"celebrities|influencers|gossip|music|film-tv|fashion-beauty|money-moves|viral|diaspora|sport-stars|real-talk|exposed\",\"score\":1-10,\"reason\":\"one sentence\"}"
            },
            {
              "name": "user",
              "value": "=Title: {{ $json.title }}\nSource: {{ $json.link }}\nSummary: {{ $json.contentSnippet || $json.summary || '' }}"
            }
          ]
        },
        "options": { "timeout": 30000 }
      },
      "id": "classify",
      "name": "AI Classify",
      "type": "n8n-nodes-base.httpRequest",
      "position": [920, 520]
    },
    {
      "parameters": {
        "jsCode": "const item = $input.first();\ntry {\n  const parsed = JSON.parse(item.json.text || '{}');\n  return [{ json: { ...item.json, ...parsed } }];\n} catch {\n  return [{ json: { ...item.json, publish: false } }];\n}"
      },
      "id": "parse-classify",
      "name": "Parse Classification",
      "type": "n8n-nodes-base.code",
      "position": [1120, 520]
    },
    {
      "parameters": {
        "conditions": {
          "boolean": [{ "value1": "={{ $json.publish }}", "value2": true }]
        }
      },
      "id": "filter-publish",
      "name": "Filter: publish=true AND score>=6",
      "type": "n8n-nodes-base.if",
      "position": [1320, 520]
    },
    {
      "parameters": {
        "operation": "insert",
        "table": "ingested_content",
        "columns": "source_url,title,summary,category,score,raw_html,status,created_at",
        "additionalFields": {}
      },
      "id": "db-insert",
      "name": "Insert to DB Queue",
      "type": "n8n-nodes-base.mysql",
      "position": [1540, 440],
      "notes": "Map: source_url=$json.link, title=$json.title, summary=$json.contentSnippet, category=$json.category, score=$json.score, raw_html=$json.content, status='queued', created_at=NOW()"
    }
  ],
  "connections": {
    "Every 2 Hours": {
      "main": [[
        { "node": "Linda Ikeji RSS", "type": "main", "index": 0 },
        { "node": "Pulse Nigeria RSS", "type": "main", "index": 0 },
        { "node": "Pulse Ghana RSS", "type": "main", "index": 0 },
