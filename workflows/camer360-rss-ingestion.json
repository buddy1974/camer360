    "Trace Africa RSS":  { "main": [[{ "node": "Deduplicate", "type": "main", "index": 0 }]] },
    "Deduplicate":          { "main": [[{ "node": "AI Classify", "type": "main", "index": 0 }]] },
    "AI Classify":          { "main": [[{ "node": "Parse Classification", "type": "main", "index": 0 }]] },
    "Parse Classification": { "main": [[{ "node": "Filter: publish=true AND score>=6", "type": "main", "index": 0 }]] },
    "Filter: publish=true AND score>=6": {
